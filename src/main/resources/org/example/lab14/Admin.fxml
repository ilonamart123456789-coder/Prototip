<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #E7E5E5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.lab14.controllers.Admin">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="54.0" style="-fx-background-color: #3B3B3B;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Label style="-fx-font-weight: bold;" text="Панель администратора" textFill="WHITE">
                    <font><Font size="15.0" /></font>
                </Label>
                <Pane HBox.hgrow="ALWAYS" />
                <Label style="-fx-font-weight: bold;" text="Админ" textFill="WHITE">
                    <font><Font size="15.0" /></font>
                    <HBox.margin><Insets right="15.0" /></HBox.margin>
                </Label>
                <Button mnemonicParsing="false" onAction="#logout" text="Выход" />
            </children>
        </HBox>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="54.0">
            <children>
                <VBox prefWidth="200.0" style="-fx-background-color: transparent; -fx-border-color: #3B3B3B; -fx-border-width: 0 1 0 0;">
                    <children>
                        <Button fx:id="btnMenu" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showMenu" prefHeight="60.0" text="Меню">
                            <font><Font size="16.0" /></font>
                        </Button>
                        <Button fx:id="btnEmployees" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showEmployees" prefHeight="60.0" text="Сотрудники">
                            <font><Font size="16.0" /></font>
                        </Button>
                        <Button fx:id="btnOrders" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showOrders" prefHeight="60.0" text="Заказы">
                            <font><Font size="16.0" /></font>
                        </Button>
                        <Button fx:id="btnCharts" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showCharts" prefHeight="60.0" text="Графики">
                            <font><Font size="16.0" /></font>
                        </Button>
                    </children>
                </VBox>

                <VBox style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label fx:id="tabTitle" text="Заголовок" style="-fx-text-fill: #3B3B3B;">
                            <font><Font name="System Bold" size="24.0" /></font>
                            <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                        </Label>

                        <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
                            <children>

                                <VBox fx:id="employeesPane" visible="false" spacing="15.0">
                                    <children>
                                        <TableView fx:id="empTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px; -fx-opacity: 0.9;">
                                            <columns>
                                                <TableColumn fx:id="colEmpId" prefWidth="50.0" text="ID" style="-fx-alignment: CENTER;" />
                                                <TableColumn fx:id="colEmpFio" prefWidth="250.0" text="ФИО" />
                                                <TableColumn fx:id="colEmpData" prefWidth="150.0" text="Дата рождения" style="-fx-alignment: CENTER;" />
                                                <TableColumn fx:id="colEmpTelefon" prefWidth="180.0" text="Номер телефона" style="-fx-alignment: CENTER;" />
                                            </columns>
                                        </TableView>

                                        <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: rgba(255, 255, 255, 0.9); -fx-padding: 10; -fx-border-color: #CCCCCC;">
                                            <TextField fx:id="fldEmpFio" promptText="ФИО" prefHeight="32.0" prefWidth="150.0" style="-fx-background-radius: 4;" />
                                            <TextField fx:id="fldEmpData" promptText="ДД.ММ.ГГГГ" prefHeight="32.0" prefWidth="100.0" style="-fx-background-radius: 4;" />
                                            <TextField fx:id="fldEmpTelefon" promptText="8 (800) ..." prefHeight="32.0" prefWidth="130.0" style="-fx-background-radius: 4;" />

                                            <Pane HBox.hgrow="ALWAYS" />
                                            <Button text="Добавить" onAction="#handleAddEmp" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #61af6f; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" textFill="WHITE" />
                                            <Button text="Изменить" onAction="#handleUpdateEmp" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #1dc3f5; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" textFill="WHITE" />
                                            <Button text="Удалить" onAction="#handleDeleteEmp" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #e06c75; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" textFill="WHITE" />
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="ordersPane" visible="false" spacing="15.0">
                                    <children>
                                        <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px; -fx-opacity: 0.9;">
                                            <columns>
                                                <TableColumn fx:id="colOrderId" prefWidth="50.0" text="ID" />
                                                <TableColumn fx:id="colDate" prefWidth="100.0" text="Дата" />
                                                <TableColumn fx:id="colTime" prefWidth="80.0" text="Время" />
                                                <TableColumn fx:id="colCheck" prefWidth="80.0" text="Чек №" />
                                                <TableColumn fx:id="colTable" prefWidth="80.0" text="Стол №" />
                                                <TableColumn fx:id="colWaiter" prefWidth="120.0" text="Официант" />
                                                <TableColumn fx:id="colTotal" prefWidth="100.0" text="Сумма" />
                                            </columns>
                                        </TableView>

                                        <Label text="Состав выбранного заказа:">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>

                                        <TableView fx:id="orderItemsTable" prefHeight="200.0" VBox.vgrow="NEVER" style="-fx-font-size: 14px; -fx-opacity: 0.9;">
                                            <columns>
                                                <TableColumn fx:id="colItemName" prefWidth="250.0" text="Блюдо" />
                                                <TableColumn fx:id="colItemPrice" prefWidth="100.0" text="Цена" />
                                                <TableColumn fx:id="colItemQty" prefWidth="80.0" text="Кол-во" />
                                                <TableColumn fx:id="colItemTotal" prefWidth="100.0" text="Итого" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>

                                <VBox fx:id="menuPane" visible="false" spacing="15.0">
                                    <children>
                                        <TableView fx:id="menuTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px; -fx-opacity: 0.9;">
                                            <columns>
                                                <TableColumn fx:id="colMenuId" prefWidth="40.0" minWidth="30.0" maxWidth="50.0" text="ID" style="-fx-alignment: CENTER;" />
                                                <TableColumn fx:id="colMenuName" prefWidth="160.0" minWidth="70.0" text="Название блюда" />
                                                <TableColumn fx:id="colMenuCategory" prefWidth="100.0" minWidth="20.0" text="Категория" />
                                                <TableColumn fx:id="colMenuSostav" prefWidth="420.0" minWidth="470.0" text="Состав" />
                                                <TableColumn fx:id="colMenuPrice" prefWidth="70.0" minWidth="10.0" text="Цена" />
                                                <TableColumn fx:id="colMenuProdan" prefWidth="120.0" minWidth="70.0" text="Продано порций" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>

                                        <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: rgba(255, 255, 255, 0.9); -fx-padding: 10; -fx-border-color: #CCCCCC;">
                                            <TextField fx:id="fldMenuName" promptText="Название" prefHeight="32.0" prefWidth="160.0" style="-fx-background-radius: 4;" />
                                            <ComboBox fx:id="cmbMenuCategory" promptText="Категория" prefHeight="32.0" prefWidth="110.0" style="-fx-background-radius: 4;" />
                                            <TextField fx:id="fldMenuSostav" promptText="Состав" prefHeight="32.0" prefWidth="250.0" style="-fx-background-radius: 4;" />
                                            <TextField fx:id="fldMenuPrice" promptText="Цена" prefHeight="32.0" prefWidth="70.0" style="-fx-background-radius: 4;" />

                                            <Button text="Добавить" onAction="#handleAddMenu" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #61af6f; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" textFill="WHITE" />

                                            <Pane HBox.hgrow="ALWAYS" />

                                            <Button text="Удалить выбранное" onAction="#handleDeleteMenu" prefHeight="32.0" prefWidth="160.0" style="-fx-background-color: #e06c75; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" textFill="WHITE" />
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="chartsPane" visible="false" spacing="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.8); -fx-padding: 15; -fx-background-radius: 8;">
                                    <children>
                                        <BarChart fx:id="barChart" VBox.vgrow="ALWAYS">
                                            <xAxis>
                                                <CategoryAxis label="Месяц" side="BOTTOM" />
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis label="Количество чеков (шт)" side="LEFT" />
                                            </yAxis>
                                        </BarChart>
                                    </children>
                                </VBox>

                            </children>
                        </StackPane>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>