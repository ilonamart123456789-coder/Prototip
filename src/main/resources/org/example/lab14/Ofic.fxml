<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #E7E5E5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.lab14.controllers.Ofic">
    <children>

        <TabPane style="-fx-background-color: transparent; -fx-tab-header-background: #E7E5E5;" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="320.0" AnchorPane.topAnchor="54.0">
            <tabs>
                <Tab style="-fx-font-size: 16px;" text="Горячее">
                    <content>
                        <AnchorPane style="-fx-background-color: transparent;">
                            <children>
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <content>
                                        <TilePane fx:id="hotTilePane" alignment="TOP_LEFT" hgap="20.0" vgap="20.0" prefTileWidth="260.0">
                                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                                        </TilePane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <Tab style="-fx-font-size: 16px;" text="Салаты">
                    <content>
                        <AnchorPane style="-fx-background-color: transparent;">
                            <children>
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <content>
                                        <TilePane fx:id="saladTilePane" alignment="TOP_LEFT" hgap="20.0" vgap="20.0" prefTileWidth="260.0">
                                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                                        </TilePane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <Tab style="-fx-font-size: 16px;" text="Напитки">
                    <content>
                        <AnchorPane style="-fx-background-color: transparent;">
                            <children>
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <content>
                                        <TilePane fx:id="drinkTilePane" alignment="TOP_LEFT" hgap="20.0" vgap="20.0" prefTileWidth="260.0">
                                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                                        </TilePane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <Tab style="-fx-font-size: 16px;" text="Десерты">
                    <content>
                        <AnchorPane style="-fx-background-color: transparent;">
                            <children>
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <content>
                                        <TilePane fx:id="dessertTilePane" alignment="TOP_LEFT" hgap="20.0" vgap="20.0" prefTileWidth="260.0">
                                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                                        </TilePane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>

        <VBox prefWidth="320.0" style="-fx-background-color: white; -fx-border-color: #3B3B3B;" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="54.0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="40.0" style="-fx-border-color: #CCCCCC; -fx-border-width: 0 0 1 0;"><padding><Insets left="10.0" right="10.0" /></padding>
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Текущий заказ"><font><Font size="16.0" /></font></Label>
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="receiptNumberLabel" style="-fx-font-weight: bold;" text="Чек №1" textFill="#1dc3f5"><font><Font size="16.0" /></font></Label>
                    </children>
                </HBox>

                <TableView fx:id="orderTableView" style="-fx-font-size: 14px; -fx-background-insets: 0; -fx-border-color: #CCCCCC; -fx-border-width: 0 0 1 0;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="dishColumn" prefWidth="180.0" text="Блюдо" />
                        <TableColumn fx:id="qtyColumn" prefWidth="50.0" style="-fx-alignment: CENTER;" text="Кол." />
                        <TableColumn fx:id="priceColumn" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Сумма" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER" prefHeight="50.0" spacing="10.0" style="-fx-background-color: #f0f0f0; -fx-border-color: #3B3B3B; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Button onAction="#decreaseItem" prefWidth="50.0" style="-fx-background-color: #1dc3f5; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" text="-" textFill="WHITE" />
                        <Button onAction="#increaseItem" prefWidth="50.0" style="-fx-background-color: #61af6f; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" text="+" textFill="WHITE" />
                        <Button onAction="#removeItem" prefWidth="100.0" style="-fx-background-color: #e06c75; -fx-border-color: #3B3B3B; -fx-border-width: 1; -fx-background-radius: 0; -fx-font-weight: bold; -fx-cursor: hand;" text="Удалить" textFill="WHITE" />
                    </children>
                    <padding><Insets bottom="10.0" top="10.0" /></padding>
                </HBox>

                <VBox alignment="CENTER" prefHeight="100.0" spacing="10.0">
                    <children>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="К оплате:"><font><Font size="18.0" /></font></Label>
                                <Label fx:id="totalLabel" style="-fx-font-weight: bold;" text="0.00"><font><Font size="22.0" /></font></Label>
                            </children>
                        </HBox>
                        <Button onAction="#processPayment" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #1dc3f5; -fx-border-color: #3B3B3B; -fx-background-radius: 0; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Оплатить (чек)" textFill="WHITE" />
                    </children>
                    <padding><Insets bottom="10.0" top="5.0" /></padding>
                </VBox>
            </children>
        </VBox>

        <Label fx:id="dateTimeLabel" style="-fx-background-color: white; -fx-border-color: black; -fx-padding: 5;" text="дата" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" />

        <HBox alignment="CENTER_LEFT" prefHeight="54.0" style="-fx-background-color: #3B3B3B;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding><Insets left="14.0" right="14.0" /></padding>
            <children>
                <Label style="-fx-font-weight: bold;" text="Оформление заказа клиента - Стол №" textFill="WHITE"><font><Font size="14.0" /></font></Label>
                <ComboBox fx:id="tableComboBox" prefHeight="25.0" prefWidth="60.0" style="-fx-font-weight: bold;">
                    <HBox.margin><Insets left="10.0" /></HBox.margin>
                </ComboBox>
                <Pane HBox.hgrow="ALWAYS" />
                <Label fx:id="waiterNameLabel" style="-fx-font-weight: bold;" text="Официант" textFill="WHITE"><font><Font size="14.0" /></font><HBox.margin><Insets right="15.0" /></HBox.margin></Label>
                <Button onAction="#logout" text="Выход" />
            </children>
        </HBox>
    </children>
</AnchorPane>